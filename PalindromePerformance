import java.util.*;

class PalindromePerformance
{
    static boolean reverseCheck(String str)
    {
        String rev = "";
        for(int i = str.length() - 1; i >= 0; i--)
        {
            rev = rev + str.charAt(i);
        }
        return str.equals(rev);
    }

    static boolean stackCheck(String str)
    {
        Stack<Character> stack = new Stack<>();

        for(char c : str.toCharArray())
        {
            stack.push(c);
        }

        for(int i = 0; i < str.length(); i++)
        {
            if(str.charAt(i) != stack.pop())
                return false;
        }

        return true;
    }

    static boolean twoPointerCheck(String str)
    {
        int start = 0;
        int end = str.length() - 1;

        while(start < end)
        {
            if(str.charAt(start) != str.charAt(end))
                return false;

            start++;
            end--;
        }

        return true;
    }

    public static void main(String[] args)
    {
        String str = "madam";

        long start, end;

        start = System.nanoTime();
        reverseCheck(str);
        end = System.nanoTime();
        System.out.println("Reverse Method Time: " + (end - start) + " ns");

        start = System.nanoTime();
        stackCheck(str);
        end = System.nanoTime();
        System.out.println("Stack Method Time: " + (end - start) + " ns");

        start = System.nanoTime();
        twoPointerCheck(str);
        end = System.nanoTime();
        System.out.println("Two Pointer Method Time: " + (end - start) + " ns");
    }
}
